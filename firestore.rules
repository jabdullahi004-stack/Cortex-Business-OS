rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. User Profiles
    match /users/{userId} {
      function isValidUserProfile(data) {
        return data.businessName is string && data.businessName.size() <= 100 &&
               data.businessType is string && data.businessType in ['Freelancer', 'Online Seller', 'Small Shop Owner', 'Agency Owner', 'Service Provider'] &&
               data.currency is string && data.currency.size() <= 10;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['businessName', 'businessType', 'currency', 'onboarded']);
    }

    // 3. Transactions
    match /transactions/{transactionId} {
      function isValidTransaction(data) {
        return data.userId == request.auth.uid &&
               data.amount is number && data.amount > 0 &&
               data.type in ['income', 'expense'] &&
               data.category is string && data.category.size() <= 50;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidTransaction(incoming()) && isValidId(transactionId);
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidTransaction(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'type', 'category', 'description', 'date']);
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    // 4. Tasks
    match /tasks/{taskId} {
      function isValidTask(data) {
        return data.userId == request.auth.uid &&
               data.title is string && data.title.size() <= 200 &&
               data.priority in ['low', 'medium', 'high'] &&
               data.status in ['todo', 'in-progress', 'completed'];
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidTask(incoming()) && isValidId(taskId);
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidTask(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'priority', 'status', 'dueDate', 'impact']);
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    // 5. Memories
    match /memories/{memoryId} {
      function isValidMemory(data) {
        return data.userId == request.auth.uid &&
               data.content is string && data.content.size() <= 5000 &&
               data.type in ['insight', 'pattern', 'routine'];
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidMemory(incoming()) && isValidId(memoryId);
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
